{
  "dashboard": {
    "uid": "curling-stream-health",
    "title": "Curling Stream Health",
    "tags": ["curling", "streaming"],
    "timezone": "browser",
    "refresh": "1m",
    "time": {"from": "now-6h", "to": "now"},
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Live Streams",
        "gridPos": {"h": 4, "w": 5, "x": 0, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "curling_stream_live_count", "refId": "A"}],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Sheets In Use",
        "gridPos": {"h": 4, "w": 5, "x": 5, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "curling_stream_expected_count", "refId": "A"}]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Missing Streams",
        "description": "Sheets in use but not streaming",
        "gridPos": {"h": 4, "w": 5, "x": 10, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "clamp_min(curling_stream_expected_count - curling_stream_live_count, 0)", "refId": "A"}],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "red", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "type": "stat",
        "title": "Monitor Up",
        "gridPos": {"h": 4, "w": 5, "x": 15, "y": 0},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [{"expr": "curling_stream_monitor_up", "refId": "A"}],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}
            ]
          }
        }
      },
      {
        "id": 7,
        "type": "timeseries",
        "title": "Streams Down Over Time",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [
          {"expr": "max by (sheet) (curling_stream_up == 0)", "refId": "A", "legendFormat": "Sheet {{sheet}}"}
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {"fillOpacity": 30, "lineWidth": 2},
            "min": 0, "max": 1,
            "color": {"mode": "palette-classic"}
          }
        }
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "Live vs In Use",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [
          {"expr": "curling_stream_live_count", "refId": "A", "legendFormat": "Live"},
          {"expr": "curling_stream_expected_count", "refId": "B", "legendFormat": "In Use (calendar)"}
        ],
        "fieldConfig": {
          "defaults": {"custom": {"fillOpacity": 10, "lineWidth": 2}, "min": 0}
        }
      },
      {
        "id": 6,
        "type": "table",
        "title": "Per-Sheet Status",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 12},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "targets": [
          {"expr": "max by (sheet) (curling_stream_up)", "refId": "A", "format": "table", "instant": true},
          {"expr": "max by (sheet) (curling_stream_resolution_height)", "refId": "B", "format": "table", "instant": true},
          {"expr": "max by (sheet) (curling_stream_bitrate_kbps)", "refId": "C", "format": "table", "instant": true},
          {"expr": "max by (sheet) (curling_stream_manifest_ok)", "refId": "D", "format": "table", "instant": true}
        ],
        "transformations": [
          {"id": "merge"},
          {"id": "organize", "options": {
            "excludeByName": {"Time": true},
            "renameByName": {
              "sheet": "Sheet",
              "Value #A": "Up",
              "Value #B": "Resolution",
              "Value #C": "Bitrate (kbps)",
              "Value #D": "Manifest OK"
            }
          }},
          {"id": "sortBy", "options": {"sort": [{"field": "Sheet"}]}}
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Up"},
              "properties": [
                {"id": "custom.cellOptions", "value": {"type": "color-background"}},
                {"id": "thresholds", "value": {"steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}},
                {"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "DOWN"}, "1": {"text": "UP"}}}]}
              ]
            },
            {
              "matcher": {"id": "byName", "options": "Manifest OK"},
              "properties": [
                {"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "No"}, "1": {"text": "OK"}}}]}
              ]
            }
          ]
        }
      }
    ]
  },
  "__inputs": [
    {"name": "DS_PROMETHEUS", "type": "datasource", "pluginId": "prometheus"}
  ]
}
